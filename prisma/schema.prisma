// Prisma schema for collabspace.
// See https://pris.ly/d/prisma-schema for syntax.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Document {
  id        String   @id
  content   Bytes
  updatedAt DateTime @updatedAt
}
