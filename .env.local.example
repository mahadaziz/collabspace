# Postgres connection string used by Prisma. Default value matches docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/collabspace?schema=public"

# Auth.js (NextAuth v5) — generate with `openssl rand -base64 32`.
# Both the Next.js app and the sync server read this to verify session JWTs.
AUTH_SECRET=

# GitHub OAuth app credentials (https://github.com/settings/developers).
# Configure the callback URL as: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# WebSocket URL the editor connects to. Override in deployment.
NEXT_PUBLIC_SYNC_URL=ws://localhost:1234
