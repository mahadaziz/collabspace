# Postgres connection string used by Prisma. Default value matches docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/collabspace?schema=public"

# NextAuth.js — generate with `openssl rand -base64 32`
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth app credentials (https://github.com/settings/developers)
GITHUB_ID=
GITHUB_SECRET=
