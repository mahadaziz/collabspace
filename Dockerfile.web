ARG NODE_VERSION=20-alpine

# Stage 1: install all deps (incl. dev) so we can build.
FROM node:${NODE_VERSION} AS deps
WORKDIR /app
RUN apk add --no-cache libc6-compat
COPY package.json package-lock.json ./
COPY prisma ./prisma
RUN npm ci

# Stage 2: build the Next.js app in standalone mode.
FROM node:${NODE_VERSION} AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# NEXT_PUBLIC_* is inlined into the client bundle at build time, so it must
# be set before `next build`. Defaulting to the local dev URL keeps `docker
# build` working without args for local testing.
ARG NEXT_PUBLIC_SYNC_URL=ws://localhost:1234
ENV NEXT_PUBLIC_SYNC_URL=$NEXT_PUBLIC_SYNC_URL
# DATABASE_URL is needed by `prisma generate` even though generate does not
# connect. A dummy value is fine.
ENV DATABASE_URL="postgres://build:build@localhost:5432/build?schema=public"
RUN npx prisma generate
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# Stage 3: minimal runtime image.
FROM node:${NODE_VERSION} AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001 -G nodejs

# Standalone bundle + static assets — used to serve the app.
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

# Separate side-tree just for running `prisma migrate deploy` at startup.
# We need the full dep graph (effect, @prisma/config, etc.) here, but we
# don't want to merge it into the standalone build's pruned node_modules.
COPY --from=builder --chown=nextjs:nodejs /app/node_modules /app/migrator/node_modules
COPY --from=builder --chown=nextjs:nodejs /app/prisma /app/migrator/prisma

# Entrypoint: migrate from the side-tree, then exec the standalone server.
COPY --chown=nextjs:nodejs <<'ENTRY' /app/entrypoint.sh
#!/bin/sh
set -e
echo "[entrypoint] running prisma migrate deploy"
cd /app/migrator
node node_modules/prisma/build/index.js migrate deploy
cd /app
echo "[entrypoint] starting next.js standalone server"
exec node server.js
ENTRY
RUN chmod +x /app/entrypoint.sh

USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
CMD ["/app/entrypoint.sh"]
